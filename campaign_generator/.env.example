# Copy this file to `.env` and fill in your real values.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Runtime defaults. CLI flags and seed values still override these.
CAMPAIGN_GENERATOR_DEFAULT_MODEL=anthropic/claude-sonnet-4.5
CAMPAIGN_GENERATOR_DRY_RUN_MODEL=anthropic/claude-haiku-4.5
CAMPAIGN_GENERATOR_DEFAULT_TEMPERATURE=0.8

# Optional transport/retry knobs.
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=120
OPENROUTER_MAX_RETRIES=3
CAMPAIGN_GENERATOR_STAGE_MAX_RETRIES=3
